[Unit]
Description=VAHAN MCP Server
After=network.target

[Service]
User=root
WorkingDirectory=/root/vahandata
ExecStart=/root/vahandata/.venv/bin/python mcp_server.py --transport http --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONPATH=.

[Install]
WantedBy=multi-user.target
